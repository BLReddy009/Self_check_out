generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  city      String?
  country   String?  @default("India")
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)

  products Product[]
  carts    Cart[]
  users    User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id         String   @id @default(cuid())
  storeId    String?
  role       String   @default("CUSTOMER")
  name       String?
  phone      String?  @unique
  email      String?  @unique
  rewardsId  String?  @unique
  otpCode    String?
  otpExpires DateTime?

  store        Store?        @relation(fields: [storeId], references: [id])
  carts        Cart[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  storeId     String
  name        String
  barcode     String
  sku         String?
  description String?
  category    String?
  price       Int
  taxRate     Float   @default(0)
  stock       Int     @default(0)
  imageUrl    String?
  modelUrl    String?
  modelFormat String?
  isActive    Boolean @default(true)

  store     Store      @relation(fields: [storeId], references: [id])
  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, barcode])
  @@index([barcode])
  @@index([storeId])
}

model Cart {
  id             String     @id @default(cuid())
  storeId        String
  userId         String?
  status         String     @default("ACTIVE")
  subtotal       Int        @default(0)
  taxTotal       Int        @default(0)
  discountTotal  Int        @default(0)
  grandTotal     Int        @default(0)
  couponCode     String?
  lockedAt       DateTime?
  paidAt         DateTime?
  abandonedAt    DateTime?
  sessionToken   String     @unique
  deviceLabel    String?
  lastActivityAt DateTime   @default(now())

  store       Store        @relation(fields: [storeId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  items       CartItem[]
  transaction Transaction?
  alerts      CartAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([status])
  @@index([lastActivityAt])
}

model CartItem {
  id           String   @id @default(cuid())
  cartId       String
  productId    String
  quantity     Int      @default(1)
  unitPrice    Int
  taxRate      Float    @default(0)
  lineSubtotal Int
  lineTax      Int
  lineTotal    Int
  scannedAt    DateTime @default(now())

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Transaction {
  id             String            @id @default(cuid())
  cartId         String            @unique
  userId         String?
  status         String            @default("PENDING")
  paymentMethod  String
  amount         Int
  taxAmount      Int
  discountAmount Int               @default(0)
  providerRef    String?
  receiptNumber  String            @unique
  receiptPdfUrl  String?
  exitQrPayload  String?
  paidAt         DateTime?
  failedReason   String?

  cart Cart  @relation(fields: [cartId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([paymentMethod])
  @@index([createdAt])
}

model CartAlert {
  id         String    @id @default(cuid())
  cartId     String
  type       String
  message    String
  isResolved Boolean   @default(false)
  resolvedAt DateTime?

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([cartId])
  @@index([type])
  @@index([isResolved])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountPercent Float?
  discountAmount  Int?
  minCartAmount   Int       @default(0)
  isActive        Boolean   @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
